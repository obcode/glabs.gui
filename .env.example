# Zwei URLs auf denselben glabs-web-Server — die SSR-Identity-Falle (siehe
# CLAUDE.md). Im Deploy zeigt PUBLIC_* auf die öffentliche, cookie-tragende URL
# (Browser), GLABS_SERVER auf den internen Hop, der den oauth2-proxy umgeht.
#
# Lokal (glabs-web mit auth.enabled: false) sind beide identisch.

# Browser → GraphQL (öffentlich, mit OIDC-Cookie)
PUBLIC_GLABS_SERVER="http://localhost:8080/query"

# SSR/Server → GraphQL (intern, umgeht den Auth-Proxy)
GLABS_SERVER="http://localhost:8080/query"

# GitLab-Host für die Token-Anleitung/Links (Default: die vom LRZ gehostete Instanz).
PUBLIC_GITLAB_HOST="https://gitlab.lrz.de"
